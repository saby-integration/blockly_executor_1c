Функция block_concatenate_calc_value(block_type, node, path, context, block_context)
 	result = "";
	prop_count = 0;
	Для каждого элем из block_context Цикл
		Если Найти(элем.Ключ, "PROP") Тогда
			prop_count = prop_count + 1;
		КонецЕсли;	
	КонецЦикла;
	Для элем = 0 По prop_count - 1 Цикл
		result = result + block_context["PROP"+элем] + 	block_context.SEPARATOR;
	КонецЦикла;
	Возврат result;
КонецФункции	
